# ─── Call Tools ───────────────────────────────────────────────
CALLTOOLS_API_KEY=tu_api_key_de_calltools
CALLTOOLS_SILO=west-4

# ─── Deepgram ─────────────────────────────────────────────────
DEEPGRAM_API_KEY=tu_api_key_de_deepgram

# ─── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=tu_api_key_de_anthropic

# ─── GHL (un solo token de agencia) ───────────────────────────
# GHL → Settings → Integrations → Private Integration Token
GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_USER_ID=id_del_usuario_ghl

# Location IDs por subcuenta (están en la URL de GHL al entrar a cada subcuenta)
# Ejemplo URL: https://app.gohighlevel.com/location/AbCdEf123/dashboard
#                                                   ^^^^^^^^^ ese es el ID
GHL_LOCATION_ID_SOLAR=location_id_de_eminded_solutions
GHL_LOCATION_ID_MITIGACION=location_id_de_saf_services

# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
